# Copy to deploy/.env (or export vars in shell) before running deploy/scripts/deploy-k8s.sh

# Target environment
FOODSEA_ENV=dev
FOODSEA_HOST=dev.<VM_PUBLIC_IP>.nip.io

# Image source
IMAGE_REGISTRY=ghcr.io/<owner>/foodsea-backend
IMAGE_TAG=<git-sha-or-tag>

# Registry credentials for image pull secret
REGISTRY_SERVER=ghcr.io
REGISTRY_USERNAME=<github-user>
REGISTRY_PASSWORD=<ghcr-read-token>

# Optional: custom smoke check endpoint
SMOKE_SCHEME=http
SMOKE_ADDR=127.0.0.1

# Optional: explicit secrets (if omitted, deploy script reuses existing k8s secret values or generates new ones)
CORE_DB_PASSWORD=<strong-password>
OPTIMIZATION_DB_PASSWORD=<strong-password>
ORDERING_DB_PASSWORD=<strong-password>
JWT_SECRET=<strong-jwt-secret>
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<strong-password>

# Voice ML feature (core-service -> ml-service VoiceService)
ML_SERVICE_VOICE_GRPC_ADDR=ml-service:50051
VOICE_REQUEST_TIMEOUT_MS=5000

# Notifications/APNS runtime settings
NOTIFICATIONS_KAFKA_GROUP_ID=core-notifications
NOTIFICATIONS_KAFKA_TOPIC=order.events
APNS_DEFAULT_ENVIRONMENT=production
APNS_BUNDLE_ID=<ios-bundle-id>
APNS_TEAM_ID=<apple-team-id>
APNS_KEY_ID=<apple-key-id>
APNS_PRIVATE_KEY=<apns-private-key-p8-content>

# ml-service Gemini settings (VoiceService shares the AnalogService gRPC port)
GEMINI_API_KEY=your-google-ai-studio-key-here
GEMINI_MODEL=gemini-embedding-2
GEMINI_OUTPUT_DIM=768
VOICE_INDEX_PATH=/app/data/voice_index.pkl
VOICE_MIN_NGRAM_SCORE=0.7
VOICE_MAX_NGRAM_LEN=3
VOICE_EMBEDDING_CACHE_SIZE=10000
