# Copy to .env.photo-search.local and fill values.
CORE_GRPC_ADDR=localhost:9091
GRPC_PORT=50051

PHOTO_SEARCH_ENABLED=true
PHOTO_SEARCH_PROVIDER=gemini_api_key
GEMINI_API_KEY=your-google-ai-studio-key-here
PHOTO_SEARCH_MODEL=gemini-embedding-2
PHOTO_SEARCH_DIMENSIONS=768
PHOTO_SEARCH_INDEX_MODE=weighted_multimodal
PHOTO_SEARCH_INDEX_PATH=data/photo_search_index.pkl
PHOTO_SEARCH_BATCH_SIZE=32
PHOTO_SEARCH_MIN_SCORE=0.25

# Build profile weights (index rebuild)
PHOTO_SEARCH_BUILD_WEIGHT_IMAGE=0.06
PHOTO_SEARCH_BUILD_WEIGHT_NAME=0.30
PHOTO_SEARCH_BUILD_WEIGHT_BRAND=0.30
PHOTO_SEARCH_BUILD_WEIGHT_CATEGORY=0.08
PHOTO_SEARCH_BUILD_WEIGHT_SUBCATEGORY=0.10
PHOTO_SEARCH_BUILD_WEIGHT_DESCRIPTION=0.06
PHOTO_SEARCH_BUILD_WEIGHT_COMPOSITION=0.05
PHOTO_SEARCH_BUILD_WEIGHT_WEIGHT=0.03
PHOTO_SEARCH_BUILD_WEIGHT_FULL_TEXT=0.02

# Query profile weights (runtime search)
PHOTO_SEARCH_QUERY_WEIGHT_IMAGE=0.10
PHOTO_SEARCH_QUERY_WEIGHT_OCR_RAW=0.10
PHOTO_SEARCH_QUERY_WEIGHT_OCR_NAME=0.30
PHOTO_SEARCH_QUERY_WEIGHT_OCR_BRAND=0.30
PHOTO_SEARCH_QUERY_WEIGHT_OCR_PERCENTAGES=0.10
PHOTO_SEARCH_QUERY_WEIGHT_OCR_VOLUME=0.10
